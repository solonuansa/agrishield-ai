# Stage 1: Build static files
FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# Stage 2: Serve with Nginx
FROM nginx:alpine

RUN adduser -D -u 1000 appuser && chown -R appuser:appuser /usr/share/nginx/html
USER appuser

COPY --from=builder /app/out /usr/share/nginx/html

EXPOSE 80 443
