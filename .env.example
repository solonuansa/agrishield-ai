# ============================================================
# AgriShield AI — Environment Variables Template
# Salin file ini ke .env dan isi nilainya
# JANGAN commit file .env ke git
# ============================================================

# ---- App ----
ENVIRONMENT=development
# ⚠️ Generate key: openssl rand -hex 32 (minimal 32 karakter!)
SECRET_KEY=ganti-dengan-random-string-minimal-32-karakter

# ---- Database ----
# ⚠️ UBAH password sebelum production! Jangan pakai default di server sungguhan
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti-ini-password-kuat
POSTGRES_DB=agrishield
DATABASE_URL=postgresql+asyncpg://postgres:ganti-ini-password-kuat@db:5432/agrishield

# ---- Redis ----
# Password opsional — jika diisi, URL akan otomatis menyertakan password
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ---- ML Service ----
ML_SERVICE_URL=http://ml-service:8001
USE_MOCK_MODEL=true
RICE_MODEL_PATH=app/models/rice_disease_v1.onnx
CORN_MODEL_PATH=app/models/corn_disease_v1.onnx

# ---- Google Gemini ----
# Hanya digunakan di backend/app/services/recommendation_service.py
# Dapatkan API key di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Object Storage (Cloudflare R2) ----
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=agrishield-images
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# URL publik untuk akses gambar (jika bucket di-set public / pakai custom domain)
R2_PUBLIC_URL=https://images.agrishield.id

# ---- Error Tracking (Sentry) ----
# Dapatkan DSN di https://sentry.io (opsional — jika kosong, Sentry tidak diaktifkan)
SENTRY_DSN=

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
