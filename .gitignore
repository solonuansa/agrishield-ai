# ============================================================
# AgriShield AI — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
.venv/
venv/
env/
.env
.env.*
!.env.example

# --- Node / Frontend ---
node_modules/
dist/
.cache/
.parcel-cache/
*.local

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker ---
*.override.yml

# --- Logs ---
*.log
logs/

# --- Database ---
*.sqlite3
*.db

# --- ML Training (seluruh folder dikecualikan) ---
ml-training/

# --- Temporary / OS ---
*.tmp
*.bak
*.orig
.cache/

# --- Superpowers / Brainstorm ---
.superpowers/
docs/superpowers/

# --- AI Agent config ---
.claude/

# --- AI Agent & Claude files (anywhere) ---
**/AGENTS.md
**/CLAUDE.md
**/.claude/

# --- Non-essential docs (not for production) ---
IMPLEMENTATION_PLAN.md
ROADMAP.md
frontend/README.md

# --- Build output ---
frontend/out/
frontend/.next/

# --- TypeScript build info ---
*.tsbuildinfo
frontend/next-env.d.ts

# --- Test coverage ---
coverage/
htmlcov/
.coverage
.coverage.*

# --- Pytest cache ---
.pytest_cache/

.github/